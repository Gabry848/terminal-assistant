{
  "name": "terminal-assistant",
  "version": "1.0.0",
  "description": "A small OpenRouter-powered terminal assistant CLI.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "terminal-assistant": "dist/index.js",
    "?": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx index.ts",
    "build": "tsc",
    "postbuild": "chmod +x dist/index.js",
    "start": "node dist/index.js",
    "link:global": "pnpm build && pnpm link --global",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
